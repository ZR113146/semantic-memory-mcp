    "layer": "semantic",
    "kind": "fact"
  },
  {
    "content": "\u9879\u76ee\u4f7f\u7528 SQLite \u5b58\u50a8\u8282\u70b9\u548c\u8fb9\uff0cFTS5 \u505a\u5168\u6587\u68c0\u7d22\uff0cyyjson \u505a JSON \u89e3\u6790",
