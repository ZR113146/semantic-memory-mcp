    "layer": "semantic",
    "kind": "fact"
  },
  {
    "content": "\u8bbe\u8ba1\u51b3\u7b56\uff1a\u8bb0\u5fc6\u7cfb\u7edf\u91c7\u7528\u5355 SQLite \u65b9\u6848\uff0c\u4e0d\u5f15\u5165\u56fe\u6570\u636e\u5e93\u6216\u5411\u91cf\u5e93",
    "layer": "semantic",
    "kind": "decision"
  },
  {
